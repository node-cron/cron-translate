{
  "name": "cron-translate",
  "version": "2.0.0",
  "description": "Translates text to cron expression",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rollup -c",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cron",
    "translate"
  ],
  "author": "Lucas Merencia <lucas@merencia.com>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-cron/cron-translate.git"
  },
  "bugs": {
    "url": "https://github.com/node-cron/cron-translate/issues"
  },
  "homepage": "https://github.com/node-cron/cron-translate#readme",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "tslib": "^2.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
